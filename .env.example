# Quick .env template — copy this to a file named .env and replace values.
# DO NOT commit the .env file to source control.

DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
ALLOWED_HOSTS=your-app.onrender.com

# Database (preferred: set DATABASE_URL for Postgres)
# Example Postgres: DATABASE_URL=postgres://user:pass@host:5432/dbname
DATABASE_URL=

# If you prefer MySQL, fill these instead (leave DATABASE_URL empty)
DB_NAME=student_job_db
DB_USER=root
DB_PASSWORD=replace-db-password
DB_HOST=127.0.0.1
DB_PORT=3306

# Media / Storage (set USE_S3=True to enable S3-compatible storage)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_CUSTOM_DOMAIN=
# For Cloudflare R2 (S3-compatible) put the R2 endpoint here, e.g.
# AWS_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
AWS_S3_ENDPOINT_URL=

# OAuth (optional - fill if you enable social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Logging & security
DJANGO_LOG_LEVEL=INFO
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True

# Optional: other flags
# USE_SENTRY=True
# SENTRY_DSN=
